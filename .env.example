# Copy these into .env.local on the server (gitignored, NEVER commit real values).

# Postgres connection used by the contact form (/api/contact) and the admin
# panel (/admin). The portfolio database is local to the VPS.
DATABASE_URL=postgres://portfolio_user:CHANGE_ME@127.0.0.1:5432/portfolio

# Admin panel (/admin) — single owner login.
# ADMIN_PASSWORD: the password you type on the /admin login screen.
# ADMIN_SESSION_SECRET: a long random string used to sign the login cookie
#   (generate with: openssl rand -hex 32). Changing it logs everyone out.
ADMIN_PASSWORD=CHANGE_ME
ADMIN_SESSION_SECRET=CHANGE_ME_LONG_RANDOM_STRING
